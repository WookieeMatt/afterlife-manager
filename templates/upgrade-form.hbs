<div class="cpr-container">
    <label class="cpr-bold">NAME OF UPGRADE:</label>
    <input type="text" name="targetSystem" class="cpr-input" placeholder="e.g., Security Turrets" style="margin-bottom: 10px;">

    <label class="cpr-bold">COST OF UPGRADE (eb):</label>
    <input type="number" name="cost" class="cpr-input" placeholder="10000000" style="margin-bottom: 10px;">

    <label class="cpr-bold">DETAILS OF UPGRADE:</label>
    <textarea name="description" class="cpr-input" rows="4" placeholder="Describe the installation..." style="margin-bottom: 15px;"></textarea>

    <label class="cpr-bold">FUNDING:</label>
    <select name="fundingSource" class="cpr-input">
        <option value="shared">Shared Fund</option>
        <option value="personal">Personal Account</option>
    </select>

    <label class="cpr-bold">DETAILS:</label>
    <textarea name="description" class="cpr-input"></textarea>
    <button type="button" class="cpr-btn approve" data-action="submitUpgrade">SUBMIT UPGRADE</button>
</div>