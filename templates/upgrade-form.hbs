<div class="cpr-container">
    <label class="cpr-bold">NAME OF UPGRADE:</label>
    <input type="text" name="targetSystem" class="cpr-input" placeholder="e.g., Security Turrets" style="margin-bottom: 10px;">

    <label class="cpr-bold">COST OF UPGRADE (eb):</label>
    <input type="number" name="cost" class="cpr-input" placeholder="1000" style="margin-bottom: 10px;">

    <label class="cpr-bold">DETAILS OF UPGRADE:</label>
    <textarea name="description" class="cpr-input" rows="4" placeholder="Describe the installation..." style="margin-bottom: 15px;"></textarea>

    <button type="button" class="cpr-btn approve" data-action="submitUpgrade" style="width: 100%;">
        SUBMIT UPGRADE
    </button>
</div>