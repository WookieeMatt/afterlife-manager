<div class="cpr-container flexcol" style="height: 100%; justify-content: space-between;">
    {{#if hasHQ}}
        <div class="top-section">
            <header class="cpr-header flexcol">
                <h2 style="margin:0; text-align:center;">AFTERLIFE MAIN TERMINAL</h2>
            </header>

            <div class="cpr-tabs flexrow" style="gap:5px; margin: 15px 0 10px 0;">
                <button type="button" class="cpr-tab-btn {{#if isTransfersTab}}active{{/if}}" data-action="switchTab" data-tab="transfers">FUND TRANSFERS</button>
                <button type="button" class="cpr-tab-btn {{#if isUpgradesTab}}active{{/if}}" data-action="switchTab" data-tab="upgrades">FACILITY UPGRADES</button>
            </div>

            <div class="cpr-scroll-area" style="max-height: 500px; overflow-y: auto; padding-right: 5px;">
                {{#if isTransfersTab}}
                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #cc0000;">REQUESTED (PENDING)</h3>
                    {{#each transferPending}}{{> requestItem req=this scenes=../expansionScenes journals=../allJournals}}{{else}}<p class="empty-text">No pending transfers.</p>{{/each}}

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #ffaa00; margin-top:15px;">ON HOLD</h3>
                    {{#each transferHold}}{{> requestItem req=this scenes=../expansionScenes journals=../allJournals}}{{else}}<p class="empty-text">No transfers on hold.</p>{{/each}}

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #00a859; margin-top:15px;">ACTIVE / COMPLETED</h3>
                    {{#each transferActive}}
                        <div class="cpr-card" style="border-left-color: #00a859; opacity: 0.8; margin-bottom:5px;">
                            <strong style="color:#00ff00;">{{amount}}eb</strong> | <small>{{actorName}} &rarr; {{targetName}} (Auth: {{userName}})</small>
                        </div>
                    {{else}}<p class="empty-text">No completed transfers.</p>{{/each}}

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #555; margin-top:15px; color:#888;">REJECTED</h3>
                    {{#each transferRejected}}
                        <div class="cpr-card" style="border-left-color: #555; opacity: 0.5; margin-bottom:5px;">
                            <strong>{{amount}}eb</strong> | <small><del>{{actorName}} &rarr; {{targetName}}</del></small>
                        </div>
                    {{/each}}
                {{/if}}

                {{#if isUpgradesTab}}
                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #cc0000;">REQUESTED PITCHES</h3>
                    {{#each upgradePending}}{{> requestItem req=this scenes=../expansionScenes journals=../allJournals}}{{else}}<p class="empty-text">No pending upgrades.</p>{{/each}}

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #ffaa00; margin-top:15px;">ON HOLD</h3>
                    {{#each upgradeHold}}{{> requestItem req=this scenes=../expansionScenes journals=../allJournals}}{{else}}<p class="empty-text">No upgrades on hold.</p>{{/each}}

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #00a859; margin-top:15px;">ACTIVE PROJECTS</h3>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                        {{#each upgradeActive}}
                            <div class="cpr-card" style="border-left-color: #00a859;">
                                <strong style="text-transform:uppercase; color:#00ff00;">{{targetSystem}}</strong><br>
                                <small>By: {{userName}} | {{cost}}eb</small>
                                {{#if linkedJournalName}}<br><small style="color: #00ff00;">DOC: {{linkedJournalName}}</small>{{/if}}
                            </div>
                        {{else}}<p class="empty-text" style="grid-column: span 2;">No active projects.</p>{{/each}}
                    </div>

                    <h3 class="cpr-highlight" style="border-bottom: 2px solid #555; margin-top:15px; color:#888;">REJECTED PITCHES</h3>
                    {{#each upgradeRejected}}
                        <div class="cpr-card" style="border-left-color: #555; opacity: 0.5; margin-bottom:5px;">
                            <strong><del>{{targetSystem}}</del></strong> | <small>Pitch by {{userName}} Denied</small>
                        </div>
                    {{/each}}
                {{/if}}
            </div>
        </div>

        <footer class="cpr-footer flexcol" style="margin-top: 15px; padding-top: 15px; border-top: 2px solid #333;">
            <h2 class="eb-text" style="text-align: center; font-size: 1.8rem; margin: 0 0 15px 0;">SHARED FUND: {{sharedFunds}}eb</h2>
            <div class="flexrow" style="gap: 10px;">
                <button type="button" class="cpr-btn" data-action="openTransferForm" style="flex:1; padding:12px; background:#222; color:#fff; border-color:#555;">INITIATE TRANSFER</button>
                <button type="button" class="cpr-btn" data-action="openUpgradeForm" style="flex:1; padding:12px; background:#222; color:#fff; border-color:#555;">PITCH UPGRADE</button>
            </div>
        </footer>
    {{else}}
        <div class="cpr-error-state" style="padding:40px; text-align:center; border:2px dashed #cc0000; color:#cc0000; font-weight:bold;">
            DATA CONNECTION LOST: CONFIGURE HQ JOURNAL IN SYSTEM SETTINGS.
        </div>
    {{/if}}
</div>

{{#*inline "requestItem"}}
<li class="inbox-item cpr-card flexcol" data-request-id="{{req.id}}" style="margin-bottom:10px; list-style:none;">
    <div class="request-info">
        {{#if (eq req.type "fund_transfer")}}
            <span class="cpr-highlight">{{req.userName}}</span>: <span style="color:#00ff00;">{{req.amount}}eb</span><br>
            <small>{{req.actorName}} &rarr; {{req.targetName}}</small>
        {{else}}
            <span class="cpr-highlight">{{req.userName}}</span> PITCHED: <span style="color:#00ff00;">{{req.targetSystem}}</span> ({{req.cost}}eb)<br>
            <small style="color:#ccc; font-style:italic;">"{{req.description}}"</small>
        {{/if}}
    </div>

    {{#if req.canApprove}}
        <div class="gm-visual-controls" style="border-top: 1px dashed #444; margin-top: 8px; padding-top: 8px;">
            <label style="font-size:0.7rem; color:#888;">GM ROUTING & DOCS</label>
            <div class="flexrow" style="gap:5px;">
                <select class="scene-select cpr-input" title="Scene Change">
                    <option value="none">No Scene Change</option>
                    {{#each scenes}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                </select>
                <select class="journal-select cpr-input" title="Link Journal Entry">
                    <option value="none">No Linked Journal</option>
                    {{#each journals}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                </select>
            </div>
            <input type="text" class="macro-input cpr-input" style="margin-top:5px;" placeholder="Trigger Macro Name">
        </div>
        <div class="flexrow" style="gap:5px; margin-top:10px;">
            <button type="button" data-action="approveReq" class="cpr-btn approve" style="flex:1; background:#00a859;">APPROVE</button>
            <button type="button" data-action="holdReq" class="cpr-btn" style="flex:1; background:#ffaa00; border-color:#ffaa00; color:#000;">HOLD</button>
            <button type="button" data-action="rejectReq" class="cpr-btn" style="flex:1;">REJECT</button>
        </div>
    {{/if}}
</li>
{{/inline}}